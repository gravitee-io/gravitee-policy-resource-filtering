{
    "id": "rf-whitelist-and-blacklist",
    "name": "rf-whitelist-and-blacklist",
    "apiVersion": "1.0",
    "definitionVersion": "4.0.0",
    "type": "proxy",
    "analytics": {},
    "listeners": [
        {
            "type": "http",
            "paths": [{ "path": "/echo" }],
            "entrypoints": [{ "type": "http-proxy" }]
        }
    ],
    "endpointGroups": [
        {
            "name": "default-group",
            "type": "http-proxy",
            "endpoints": [
                {
                    "name": "default",
                    "type": "http-proxy",
                    "weight": 1,
                    "inheritConfiguration": false,
                    "configuration": { "target": "http://localhost:8080/endpoint" }
                }
            ]
        }
    ],
    "flows": [
        {
            "name": "flow",
            "enabled": true,
            "selectors": [{ "type": "http", "path": "/", "pathOperator": "STARTS_WITH" }],
            "request": [
                {
                    "name": "Resource Filtering",
                    "enabled": true,
                    "policy": "resource-filtering",
                    "configuration": {
                        "whitelist": [{ "pattern": "**/api/**" }],
                        "blacklist": [{ "pattern": "**/api/admin/**" }]
                    }
                }
            ],
            "response": [],
            "subscribe": [],
            "publish": []
        }
    ]
}
